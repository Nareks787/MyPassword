<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#023020">

    <!-- Круг ПЕРВЫЙ (до иконки) -->
    <View
        android:id="@+id/iconBackground"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginTop="117dp"
        android:background="@drawable/circle_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Иконка ВТОРАЯ (поверх круга) -->
    <ImageView
        android:id="@+id/icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="130dp"
        android:src="@drawable/ic_lock"
        app:tint="#D4A373"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:letterSpacing="-0.02"
        android:text="MyPassWord"
        android:textColor="#D4A373"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="secure · simple · yours"
        android:textColor="#80D4A373"
        android:textSize="13sp"
        android:letterSpacing="0.05"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnOpen"
        android:layout_width="260dp"
        android:layout_height="52dp"
        android:layout_marginTop="40dp"
        android:backgroundTint="#D4A373"
        android:stateListAnimator="@null"
        android:text="@string/open_app"
        android:textColor="#023020"
        android:textSize="17sp"
        android:textStyle="bold"
        app:cornerRadius="14dp"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/about_us"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="260dp"
        android:layout_height="52dp"
        android:layout_marginTop="14dp"
        android:text="@string/about_us"
        android:textSize="17sp"
        android:textColor="#D4A373"
        app:strokeColor="#73D4A373"
        app:strokeWidth="1.5dp"
        app:cornerRadius="14dp"
        app:layout_constraintTop_toBottomOf="@id/btnOpen"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>