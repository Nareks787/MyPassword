<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/password_manager_title"
        android:textColor="@color/app_text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnAddPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/add_password"
        android:textAllCaps="false" />

    <ListView
        android:id="@+id/listPasswords"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/app_surface"
        android:divider="#334155"
        android:dividerHeight="1dp"
        android:padding="4dp" />

</LinearLayout>
