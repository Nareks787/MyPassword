<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#023020">

    <!-- Title -->
    <TextView
        android:text="Детали записи"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#D4A373"
        android:layout_marginBottom="24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Site label -->
    <TextView
        android:text="Сайт:"
        android:textSize="14sp"
        android:textColor="#80D4A373"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Site value -->
    <TextView
        android:id="@+id/tvSite"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#A8C5A0"
        android:layout_marginBottom="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Login label -->
    <TextView
        android:text="Логин:"
        android:textSize="14sp"
        android:textColor="#80D4A373"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Login value -->
    <TextView
        android:id="@+id/tvLogin"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#A8C5A0"
        android:layout_marginBottom="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Password label -->
    <TextView
        android:text="Пароль:"
        android:textSize="14sp"
        android:textColor="#80D4A373"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Password value -->
    <TextView
        android:id="@+id/tvPassword"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#A8C5A0"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Show Password Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnShowPassword"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="32dp"
        android:text="Показать пароль"
        android:textSize="15sp"
        android:textColor="#D4A373"
        android:textStyle="bold"
        app:backgroundTint="#0A3020"
        app:strokeColor="#D4A373"
        app:strokeWidth="1dp"
        app:cornerRadius="14dp" />

    <!-- Edit Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEdit"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="8dp"
        android:text="Редактировать"
        android:textSize="15sp"
        android:textColor="#023020"
        android:textStyle="bold"
        app:backgroundTint="#D4A373"
        app:cornerRadius="14dp" />

    <!-- Delete Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDelete"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Удалить"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:backgroundTint="#8B1A1A"
        app:cornerRadius="14dp" />

</LinearLayout>